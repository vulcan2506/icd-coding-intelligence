Stage 1/.claude/
*.env
.env

# ── Python / venv ────────────────────────────────────────────────────────────
venv/
__pycache__/
*.pyc
.deepeval/

# ── Pipeline data ────────────────────────────────────────────────────────────
# Unlike the original HealthRules corpus (licensed product docs), the ICD-10-CM
# guideline PDFs are public CMS documents — Stage 1/data/ (pdfs + output) and
# retrieval_layer/chroma_db/ + index/ are committed in full, not excluded.
# chroma_db/ and index/ large binaries go through Git LFS (see .gitattributes).

# Eval/deep-eval reports & logs quote real retrieved excerpts verbatim and are
# regenerated by eval.py --compare / deep_eval.py — not source.
retrieval_layer/eval_report.md*
retrieval_layer/deep_eval*.md
retrieval_layer/deep_eval*.log

# ── Personal/working files not needed in the repo ───────────────────────────
Stage 1/*.log
Stage 1/WhatsApp Image*.jpeg
