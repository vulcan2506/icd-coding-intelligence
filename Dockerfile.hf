# Backend deploy image for Hugging Face Spaces (Docker SDK).
# Same service as Dockerfile.backend (Render), with two HF-specific changes:
#   1. Bundles redis-server IN this container and starts it before uvicorn —
#      HF Spaces has no managed Redis add-on, but (unlike Vercel) its
#      container is one long-lived process, so a sidecar redis-server is a
#      sound, self-contained substitute. Cache data is ephemeral across
#      Space restarts (no persistent volume on the free tier) — acceptable,
#      since it's a demo response cache, not the corpus itself.
#   2. Default port 7860 (HF Spaces convention — see README.md's app_port).
#
# Build context is the REPO ROOT, same as Dockerfile.backend — see that
# file's header comment for why both Stage 1/ and retrieval_layer/ are
# needed. Docling included here too (same USE_CLAUDE_OCR-fallback role).

FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libgl1 \
    libglib2.0-0 \
    libgomp1 \
    redis-server \
    && rm -rf /var/lib/apt/lists/*

COPY retrieval_layer/requirements-serve.txt ./requirements-serve.txt
RUN pip install --no-cache-dir -r requirements-serve.txt

# HF Spaces runs the container as UID 1000 regardless of this Dockerfile's
# (absent) USER directive — without --chown, these stay root-owned and any
# runtime write under them (chromadb's SQLite WAL/lock files next to the
# baked-in corpus, __pycache__, etc.) fails under the platform's actual UID.
COPY --chown=1000:1000 ["Stage 1", "./Stage 1"]
COPY --chown=1000:1000 retrieval_layer ./retrieval_layer

WORKDIR /app/retrieval_layer

ENV PORT=7860
ENV PYTHONUNBUFFERED=1
EXPOSE 7860

# redis-server's daemonize mode defaults to writing its pidfile into CWD
# (root-owned from the build); pointing it at /tmp (writable by any UID)
# avoids a silent failure under HF's UID-1000 runtime.
CMD ["sh", "-c", "redis-server --dir /tmp --pidfile /tmp/redis.pid --logfile /tmp/redis.log --daemonize yes && uvicorn api_server:app --host 0.0.0.0 --port ${PORT}"]
